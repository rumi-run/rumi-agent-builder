# RUMI Agent Builder - Environment Variables

# Server
BUILDER_PORT=3020
BUILDER_HOST=0.0.0.0
BUILDER_DB_PATH=./data/builder.db
NODE_ENV=development

# Set to 1 when behind Nginx/Caddy so rate limits and req.ip use the real client (X-Forwarded-For).
# BUILDER_TRUST_PROXY=1

# SMTP (iCloud: smtp.mail.me.com:587; use an app-specific password, never commit real secrets)
RUMI_SMTP_HOST=smtp.mail.me.com
RUMI_SMTP_PORT=587
RUMI_SMTP_USER=
RUMI_SMTP_PASS=
RUMI_EMAIL_FROM=noreply@rumi.run

# Admin emails (comma-separated). Required for OTP sign-in: first login with one of these becomes admin.
RUMI_ADMIN_EMAILS=admin@rumi.run

# Optional: fixed setup token for the /builder/setup form instead of data/.setup_token (min. 8 characters).
# RUMI_SETUP_TOKEN=

# Super admin (comma-separated). Can approve system template submissions for the public gallery. If empty, same set as RUMI_ADMIN_EMAILS is used where applicable.
RUMI_SUPERADMIN_EMAILS=

# Encrypts the AI API key stored by admins (AES-256-GCM). Required in production when saving a new key. Use a long random secret (32+ characters). Existing plaintext keys in DB keep working until re-saved.
RUMI_AI_CONFIG_SECRET=

# Optional: same-site session from another service (server-side GET internalUrl/me with forwarded Cookie).
# Leave both empty to use only this app's email OTP (default). Set both to enable the bridge.
# BUILDER_AUTH_BRIDGE_INTERNAL_URL=http://127.0.0.1:3030
# BUILDER_AUTH_BRIDGE_COOKIE_NAME=session_cookie_name
# Deprecated aliases (still supported): RUMI_SSO_INTERNAL_URL, RUMI_SSO_COOKIE_NAME
