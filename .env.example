# RUMI Agent Builder - Environment Variables

# Server
BUILDER_PORT=3020
BUILDER_HOST=0.0.0.0
BUILDER_DB_PATH=./data/builder.db
NODE_ENV=development

# SMTP (iCloud: smtp.mail.me.com:587 — use App 专用密码，勿提交真实密码到 Git)
RUMI_SMTP_HOST=smtp.mail.me.com
RUMI_SMTP_PORT=587
RUMI_SMTP_USER=
RUMI_SMTP_PASS=
RUMI_EMAIL_FROM=noreply@beok.net

# Admin emails (comma-separated)
RUMI_ADMIN_EMAILS=admin@rumi.run

# 统一登录服务（本机 rumi-unified-auth，与 Cookie rumi_sso 一致）
RUMI_SSO_INTERNAL_URL=http://127.0.0.1:3030
RUMI_SSO_COOKIE_NAME=rumi_sso
