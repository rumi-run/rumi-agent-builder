{
  "name": "rumi-agent-builder",
  "version": "1.0.0",
  "private": false,
  "description": "RUMI Agent Builder - Visual AI agent planning platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npx vite --host 0.0.0.0 --port 5173",
    "dev:server": "cd server && node index.js",
    "build": "cd client && npx vite build",
    "preview": "cd client && npx vite preview",
    "start": "node server/index.js"
  },
  "keywords": [
    "rumi",
    "agent",
    "builder",
    "ai"
  ],
  "author": "RUMI",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "ws": "^8.19.0"
  }
}
